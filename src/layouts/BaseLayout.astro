---
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { withBase } from '../lib/utils';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Small Joys Calendar',
  description = 'A calm 12-week calendar of gentle outings around Marsham and Norwich.'
} = Astro.props;

const pageTitle = `${title} | Small Joys Calendar`;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.pathname;
const socialImage = Astro.site
  ? new URL(withBase('/images/social-preview.svg'), Astro.site).toString()
  : withBase('/images/social-preview.svg');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f2ece3" />
    <link rel="icon" href={withBase('/favicon.svg')} type="image/svg+xml" />
    <link rel="canonical" href={canonical} />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

  </head>
  <body>
    <div class="page-shell">
      <SiteHeader />
      <main id="content" class="page-content">
        <slot />
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
