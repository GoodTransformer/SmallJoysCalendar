---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ActivityCard from '../../components/ActivityCard.astro';
import CategoryCard from '../../components/CategoryCard.astro';
import { calendar } from '../../data/calendar';

const allActivities = calendar.activities;
---

<BaseLayout title="Categories" description="Browse calm ideas by budget, weather, dog-friendliness, and water-based fit.">
  <section class="panel">
    <div class="section-heading">
      <h1 class="week-page__headline">Browse by mood, logistics, or spend</h1>
      <p>Browse the same ideas by mood, budget, weather, or company.</p>
    </div>
    <div class="category-grid">
      {calendar.categories.map((category) => (
        <CategoryCard category={category} />
      ))}
    </div>
  </section>

  <section class="section-block">
    <div class="filter-panel">
      <div class="filter-panel__header">
        <div>
          <h2>Filter</h2>
          <p class="filter-panel__hint">Pick a few tags to narrow the list.</p>
        </div>
        <button class="filter-panel__clear" type="button" data-clear-filters hidden>Clear filters</button>
      </div>
      <div class="filter-panel__chips">
        <label class="filter-chip"><input type="checkbox" value="wednesday" data-label="Wednesday-friendly" /> Wednesday-friendly</label>
        <label class="filter-chip"><input type="checkbox" value="weekend" data-label="Weekend-friendly" /> Weekend-friendly</label>
        <label class="filter-chip"><input type="checkbox" value="dog-friendly" data-label="Dog-friendly" /> Dog-friendly</label>
        <label class="filter-chip"><input type="checkbox" value="indoor" data-label="Indoor" /> Indoor</label>
        <label class="filter-chip"><input type="checkbox" value="under-40" data-label="Under £40" /> Under £40</label>
        <label class="filter-chip"><input type="checkbox" value="around-80" data-label="Around £80" /> Around £80</label>
        <label class="filter-chip"><input type="checkbox" value="water" data-label="Water-based" /> Water-based</label>
      </div>
      <div class="filter-panel__status">
        <p class="filter-panel__count" data-filter-count>Showing all {allActivities.length} activities.</p>
        <div class="filter-panel__active" data-active-filters hidden>
          <p class="filter-panel__active-label">Active filters</p>
          <div class="filter-panel__active-list" data-active-filter-list></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-block">
    <div class="section-heading">
      <h2>All activities</h2>
    </div>

    <p class="empty-state" data-empty-state hidden>No activities match the selected filters.</p>

    <div class="activity-grid" data-filter-grid>
      {allActivities.map((activity) => (
        <div
          data-activity-card
          data-tags={activity.tags.join('|').toLowerCase()}
          data-timing={activity.timingFit.toLowerCase()}
          data-dog={activity.dogFriendly.toLowerCase()}
          data-indoor={String(activity.indoor)}
          data-price={activity.priceBand}
          data-water={String(activity.waterBased)}
        >
          <ActivityCard activity={activity} />
        </div>
      ))}
    </div>
  </section>

  <script>
    const checkboxes = Array.from(document.querySelectorAll<HTMLInputElement>('.filter-chip input'));
    const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-activity-card]'));
    const emptyState = document.querySelector<HTMLElement>('[data-empty-state]');
    const count = document.querySelector<HTMLElement>('[data-filter-count]');
    const activeFilters = document.querySelector<HTMLElement>('[data-active-filters]');
    const activeFilterList = document.querySelector<HTMLElement>('[data-active-filter-list]');
    const clearFilters = document.querySelector<HTMLButtonElement>('[data-clear-filters]');
    const filterLabels = new Map(
      checkboxes.map((input) => [input.value, input.dataset.label ?? input.value])
    );

    const matches = (card: HTMLElement, value: string) => {
      const tags = card.dataset.tags ?? '';
      const timing = card.dataset.timing ?? '';
      const dog = card.dataset.dog ?? '';
      const indoor = card.dataset.indoor ?? '';
      const price = card.dataset.price ?? '';
      const water = card.dataset.water ?? '';

      if (value === 'wednesday') return timing === 'wednesday' || tags.includes('wednesday');
      if (value === 'weekend') return timing === 'weekend' || timing === 'either' || tags.includes('weekend');
      if (value === 'dog-friendly') return dog === 'yes' || tags.includes('dog-friendly');
      if (value === 'indoor') return indoor === 'true' || tags.includes('indoor');
      if (value === 'under-40') return price === 'under-40' || tags.includes('under-£40');
      if (value === 'around-80') return price === 'around-80' || tags.includes('around-£80');
      if (value === 'water') return water === 'true' || tags.includes('water');
      return true;
    };

    const update = () => {
      const active = checkboxes.filter((input) => input.checked).map((input) => input.value);
      let visibleCount = 0;

      cards.forEach((card) => {
        const visible = active.every((value) => matches(card, value));
        card.hidden = !visible;
        if (visible) visibleCount += 1;
      });

      if (emptyState) {
        emptyState.hidden = visibleCount !== 0;
      }

      if (count) {
        count.textContent = active.length === 0
          ? `Showing all ${cards.length} activities.`
          : `${visibleCount} ${visibleCount === 1 ? 'activity matches' : 'activities match'} the selected filters.`;
      }

      if (activeFilters && activeFilterList) {
        activeFilterList.replaceChildren(
          ...active.map((value) => {
            const button = document.createElement('button');
            button.type = 'button';
            button.className = 'filter-panel__active-chip';
            button.dataset.removeFilter = value;
            button.textContent = `${filterLabels.get(value) ?? value} ×`;
            return button;
          })
        );
        activeFilters.hidden = active.length === 0;
      }

      if (clearFilters) {
        clearFilters.hidden = active.length === 0;
      }
    };

    checkboxes.forEach((input) => input.addEventListener('change', update));
    activeFilterList?.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLButtonElement)) return;

      const filter = target.dataset.removeFilter;
      const input = checkboxes.find((item) => item.value === filter);

      if (input) {
        input.checked = false;
        update();
      }
    });

    clearFilters?.addEventListener('click', () => {
      checkboxes.forEach((input) => {
        input.checked = false;
      });
      update();
    });

    update();
  </script>
</BaseLayout>
